{
  "Main Function": {
    "prefix": "izmain",
    "body": [
      "iz main() {",
      "    $0",
      "}"
    ],
    "description": "Create a main function"
  },
  "Print": {
    "prefix": "meow",
    "body": "meow!(\"${1:hai world}\");",
    "description": "Print to stdout"
  },
  "Error Print": {
    "prefix": "hisss",
    "body": "hisss!(\"${1:oh noes}\");",
    "description": "Print to stderr"
  },
  "Let Binding": {
    "prefix": "icanhaz",
    "body": "i can haz ${1:name} = ${2:value};",
    "description": "Immutable let binding"
  },
  "Let Mut": {
    "prefix": "icanhazwiggly",
    "body": "i can haz wiggly ${1:name} = ${2:value};",
    "description": "Mutable let binding"
  },
  "If": {
    "prefix": "ifcat",
    "body": [
      "if ceiling cat sez ${1:condition} {",
      "    $0",
      "}"
    ],
    "description": "If statement"
  },
  "If Else": {
    "prefix": "ifelse",
    "body": [
      "if ceiling cat sez ${1:condition} {",
      "    $2",
      "} or basement cat sez {",
      "    $0",
      "}"
    ],
    "description": "If/else statement"
  },
  "Loop": {
    "prefix": "zoomies",
    "body": [
      "zoomies {",
      "    $0",
      "}"
    ],
    "description": "Infinite loop"
  },
  "For Loop": {
    "prefix": "chase",
    "body": [
      "chase ${1:i} around ${2:0..10} {",
      "    $0",
      "}"
    ],
    "description": "For loop"
  },
  "Match": {
    "prefix": "sniff",
    "body": [
      "sniff ${1:value} {",
      "    ${2:pattern} => ${3:result},",
      "    $0",
      "}"
    ],
    "description": "Match expression"
  },
  "Struct": {
    "prefix": "loaf",
    "body": [
      "loaf ${1:Name} {",
      "    $0",
      "}"
    ],
    "description": "Define a struct"
  },
  "Impl": {
    "prefix": "teech",
    "body": [
      "teech ${1:Name} {",
      "    $0",
      "}"
    ],
    "description": "Impl block"
  },
  "Enum": {
    "prefix": "flavurz",
    "body": [
      "flavurz ${1:Name} {",
      "    $0",
      "}"
    ],
    "description": "Define an enum"
  },
  "Trait": {
    "prefix": "skillz",
    "body": [
      "skillz ${1:Name} {",
      "    $0",
      "}"
    ],
    "description": "Define a trait"
  },
  "Function": {
    "prefix": "iz",
    "body": [
      "iz ${1:name}(${2:}) -> ${3:ReturnType} {",
      "    $0",
      "}"
    ],
    "description": "Define a function"
  },
  "Option Match": {
    "prefix": "sniffmaybe",
    "body": [
      "sniff ${1:maybe_value} {",
      "    Has(${2:val}) => $3,",
      "    EmptyBowl => $0,",
      "}"
    ],
    "description": "Match on Option (MaybeCheezburgr)"
  },
  "Result Match": {
    "prefix": "snifftryz",
    "body": [
      "sniff ${1:result} {",
      "    Purrfect(${2:val}) => $3,",
      "    Hairball(${4:err}) => $0,",
      "}"
    ],
    "description": "Match on Result (Tryz)"
  },
  "Unsafe Block": {
    "prefix": "yolo",
    "body": [
      "yolo {",
      "    // HERE BE DRAGONS",
      "    $0",
      "}"
    ],
    "description": "Unsafe block (YOLO mode)"
  },
  "Hello World": {
    "prefix": "helloworld",
    "body": [
      "iz main() {",
      "    meow!(\"Oh hai world! :3\");",
      "}"
    ],
    "description": "Hello world program"
  }
}
